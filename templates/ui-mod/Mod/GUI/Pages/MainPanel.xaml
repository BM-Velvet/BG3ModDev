<!--
    __MOD_NAME__ — Main Panel
    Root is a Canvas whose Visibility is controlled by the Lua ViewModel (not BG3 state machine).
    Bind Canvas.Visibility to a VM string property: "Visible" / "Collapsed".

    IMPORTANT Noesis rules:
      - Use http:// not https:// in xmlns (https:// crashes the game)
      - Never cache Noesis proxy objects between calls — always re-find them
      - Use Trigger Property="Tag" not DataTrigger for binding-driven Tag changes
-->
<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ls="clr-namespace:ls;assembly=MainUI"
        Visibility="{Binding Visibility}"
        Width="600" Height="400">

    <Canvas.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MainUI;component/Assets/__MOD_NAME__/GUI/Resources/Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Canvas.Resources>

    <!-- Panel background -->
    <Border Canvas.Left="0" Canvas.Top="0"
            Width="600" Height="400"
            Background="#CC000000"
            BorderBrush="#806040"
            BorderThickness="2"
            CornerRadius="4">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#80402010" CornerRadius="4,4,0,0">
                <Grid>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="__MOD_NAME__"
                               Foreground="#FFD4A84B"
                               FontSize="16"/>
                    <!-- Close button -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0" Width="24" Height="24"
                            Content="X"
                            Command="{Binding CloseCommand}"
                            Foreground="#FFD4A84B"/>
                </Grid>
            </Border>

            <!-- Content area — add your UI here -->
            <Grid Grid.Row="1" Margin="8">
                <TextBlock Text="Panel content goes here"
                           Foreground="#FFCCCCCC"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#80201008" CornerRadius="0,0,4,4">
                <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center"
                           Margin="8,0"
                           Text="{Binding StatusText}"
                           Foreground="#FF888888"
                           FontSize="12"/>
            </Border>
        </Grid>
    </Border>
</Canvas>
